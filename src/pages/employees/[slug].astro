---
import Layout from "../../layouts/Layout.astro";
import employees from "../../data/employees.json";
import Instagram from "@icons/instagram.svg";
import Facebook from "@icons/facebook.svg";

export async function getStaticPaths() {
  return employees.map((employee) => ({
    params: { slug: employee.slug },
    props: { employee },
  }));
}

const { employee } = Astro.props;
---

<Layout title={employee.name}>
  <main class="employee-page">
    <section class="employee-section">
      <div class="container">
        <div class="employee-layout">
          <div class="left-column">
            <div class="image-stack">
              <div class="green-box"></div>
              <img src={employee.img} alt={employee.name} class="employee-image" />
            </div>

            <div class="socials">
              {
                employee.social_links?.map((social) => (
                  <a href={social.url} target="_blank" rel="noopener noreferrer" aria-label={social.platform}>
                    <span class="social-icon" aria-label={social.platform}>
                      {social.icon === "instagram" && <Instagram />}
                      {social.icon === "facebook" && <Facebook />}
                    </span>
                  </a>
                ))
              }
            </div>
          </div>

          <div class="right-column">
            <h1>{employee.name}</h1>
            <p class="job-title">{employee.title}</p>

            <p class="body-text">{employee.description_long}</p>

            <hr />

            <h2>Past experience</h2>
            <p class="body-text">{employee.past_experience}</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .employee-page {
    background: #f3f3f3;
    min-height: 100vh;
  }

  .employee-section {
    padding: 4rem 1.5rem 5rem;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .employee-layout {
    display: grid;
    grid-template-columns: 420px 1fr;
    gap: 4rem;
    align-items: start;
  }

  .left-column {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .image-stack {
    position: relative;
    width: 100%;
    max-width: 370px;
    min-height: 430px;
  }

  .green-box {
    position: absolute;
    top: -30px;
    left: -40px;
    width: 180px;
    height: 125px;
    background: #9be39b;
    border-radius: 16px;
    z-index: 1;
  }

  .employee-image {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 370px;
    height: auto;
    display: block;
    border-radius: 18px;
    object-fit: cover;
  }

  .socials {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 1rem;
  }

  .socials a {
    width: 24px;
    height: 24px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #111827;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  .socials a:hover {
    opacity: 0.75;
    transform: translateY(-2px);
  }

  .socials svg {
    width: 22px;
    height: 22px;
    display: block;
  }

  .right-column h1 {
    font-size: 3rem;
    line-height: 1.1;
    margin: 0 0 0.35rem;
    color: #111827;
    font-weight: 700;
  }

  .job-title {
    margin: 0 0 2rem;
    font-size: 1.35rem;
    color: #6b7280;
  }

  .body-text {
    font-size: 1.05rem;
    line-height: 1.9;
    color: #6b7280;
    margin: 0;
  }

  hr {
    border: none;
    border-top: 1px solid #d1d5db;
    margin: 2.5rem 0;
  }

  .right-column h2 {
    font-size: 2.2rem;
    line-height: 1.2;
    margin: 0 0 1rem;
    color: #111827;
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .employee-layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .left-column {
      align-items: flex-start;
    }

    .socials {
      justify-content: flex-start;
    }

    .green-box {
      left: -10px;
      top: -20px;
      width: 140px;
      height: 100px;
    }

    .right-column h1 {
      font-size: 2.2rem;
    }

    .right-column h2 {
      font-size: 1.8rem;
    }
  }
</style>
