---
const { employee } = Astro.props;
---

<article class="employee-card">
  <div class="image-wrapper">
    <img src={employee.img} alt={employee.name} class="employee-image" />
    <span class="badge">{employee.title}</span>
  </div>

  <div class="card-content">
    <h2>{employee.name}</h2>
    <p class="description">{employee.description}</p>

    <div class="socials">
      {
        employee.social_links?.map((social) => (
          <a href={social.url} aria-label={social.platform} target="_blank" rel="noopener noreferrer">
            {social.icon === "instagram" && (
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2Zm0 1.5A4.25 4.25 0 0 0 3.5 7.75v8.5A4.25 4.25 0 0 0 7.75 20.5h8.5a4.25 4.25 0 0 0 4.25-4.25v-8.5A4.25 4.25 0 0 0 16.25 3.5h-8.5Zm8.88 1.75a1.12 1.12 0 1 1 0 2.24 1.12 1.12 0 0 1 0-2.24ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 1.5A3.5 3.5 0 1 0 12 15.5 3.5 3.5 0 0 0 12 8.5Z" />
              </svg>
            )}

            {social.icon === "facebook" && (
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M13.5 22v-8h2.7l.4-3h-3.1V9.1c0-.9.3-1.6 1.6-1.6h1.7V4.8c-.3 0-1.3-.1-2.4-.1-2.4 0-4 1.4-4 4.1V11H8v3h2.4v8h3.1Z" />
              </svg>
            )}
          </a>
        ))
      }
    </div>
  </div>
</article>

<style>
  .employee-card {
    width: 100%;
    max-width: 320px;
    margin: 0 auto;
    text-align: center;
  }

  .image-wrapper {
    position: relative;
    border-radius: 18px;
    overflow: hidden;
    margin-bottom: 18px;
  }

  .employee-image {
    width: 100%;
    height: 360px;
    object-fit: cover;
    display: block;
    border-radius: 18px;
  }

  .badge {
    position: absolute;
    bottom: 12px;
    right: 12px;
    background: #0f172a;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    line-height: 1;
  }

  .card-content {
    padding: 0 0.5rem 0.75rem;
  }

  h2 {
    font-size: 2rem;
    font-weight: 700;
    color: #111827;
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }

  .description {
    font-size: 0.95rem;
    line-height: 1.6;
    color: #6b7280;
    max-width: 280px;
    margin: 0 auto 1rem;
  }

  .socials {
    display: flex;
    justify-content: center;
    gap: 1rem;
  }

  .socials a {
    width: 22px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #111827;
    transition:
      transform 0.2s ease,
      opacity 0.2s ease;
  }

  .socials a:hover {
    transform: translateY(-2px);
    opacity: 0.8;
  }

  .socials svg {
    width: 20px;
    height: 20px;
    display: block;
  }
</style>
