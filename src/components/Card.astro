---
const { employee } = Astro.props;
import Instagram from "@icons/instagram.svg";
import Facebook from "@icons/facebook.svg";
---

<a href={`/employees/${employee.slug}`} class="card-link">
  <article class="employee-card">
    <div class="image-wrapper">
      <img src={employee.img.replace("/src/data/images/", "/images/").replace("/src/data/img/", "/images/")} alt={employee.name} class="employee-image" />
      <span class="badge">{employee.title}</span>
    </div>
    <div class="card-content">
      <h2>{employee.name}</h2>
      <p class="description">{employee.description}</p>

      <div class="socials">
        {
          employee.social_links?.map((social) => (
            <span class="social-icon" aria-label={social.platform}>
              {social.icon === "instagram" && <Instagram />}
              {social.icon === "facebook" && <Facebook />}
            </span>
          ))
        }
      </div>
    </div>
  </article>
</a>

<style>
  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .employee-card {
    width: 100%;
    max-width: 320px;
    margin: 0 auto;
    text-align: center;
    transition: transform 0.25s ease;
  }

  .card-link:hover .employee-card {
    transform: scale(1.02);
  }

  .image-wrapper {
    position: relative;
    border-radius: 18px;
    overflow: hidden;
    margin-bottom: 18px;
  }

  .employee-image {
    width: 100%;
    height: 360px;
    object-fit: cover;
    display: block;
    border-radius: 18px;
  }

  .badge {
    position: absolute;
    bottom: 12px;
    right: 12px;
    background: #0f172a;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    line-height: 1;
  }

  .card-content {
    padding: 0 0.5rem 0.75rem;
  }

  h2 {
    font-size: 2rem;
    font-weight: 700;
    color: #111827;
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }

  .description {
    font-size: 0.95rem;
    line-height: 1.6;
    color: #6b7280;
    max-width: 280px;
    margin: 0 auto 1rem;
  }

  .socials {
    display: flex;
    justify-content: center;
    gap: 1rem;
  }

  .social-icon {
    width: 64px;
    height: 64px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #111827;
  }

  .social-icon :global(svg) {
    width: 64px;
    height: 64px;
    display: block;
  }
</style>
